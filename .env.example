# ---- Network ----
# "testnet" -> Celo Sepolia (eip155:11142220), "mainnet" -> Celo (eip155:42220)
X402_NETWORK=testnet

# ---- Seller (server.ts) ----
# API key from the Celo Builders dashboard: https://x402.celobuilders.xyz
# (connect an EVM wallet, sign to create a key). Required by the facilitator.
X402_API_KEY=x402_...
# Wallet address that receives the payment. Never the facilitator address.
SELLER_PAY_TO=0xYourReceivingAddress
# Port the seller listens on.
PORT=3000

# ---- Buyer / agent (agent.ts) ----
# Private key of a wallet funded with Celo Sepolia test USDC.
# The facilitator sponsors settlement gas, so this wallet needs USDC, not CELO.
BUYER_PRIVATE_KEY=0xYourFundedTestWalletPrivateKey
# Where the buyer sends its request (the seller from server.ts).
# Point this at the deployed URL (e.g. https://x402-celo-demo.vercel.app) to pay
# the live endpoint instead of a local one.
SERVER_URL=http://localhost:3000

# ---- Attribution (ERC-8021, @celo/attribution-tags) ----
# The app's attribution code is derived from its hostname. On Vercel it comes
# from the deployment domain automatically; set one of these to override.
# ATTRIBUTION_HOSTNAME=x402-celo-demo.vercel.app
# ATTRIBUTION_CODE=celo_xxxxxxxxxxxx
